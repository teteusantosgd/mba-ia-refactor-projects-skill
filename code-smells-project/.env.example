# Configuração da aplicação (copie para .env e ajuste os valores)

# Chave secreta da aplicação. Em produção é obrigatória; sem ela, uma chave
# efêmera aleatória é gerada por processo.
SECRET_KEY=

# Habilita o modo debug do Flask (nunca use "true" em produção).
DEBUG=false

# Caminho do arquivo SQLite.
DATABASE_PATH=loja.db

# Host e porta do servidor.
HOST=0.0.0.0
PORT=5000

# Ambiente reportado pelo /health.
ENVIRONMENT=producao

# Token exigido no header X-Admin-Token para operações administrativas
# destrutivas (ex.: /admin/reset-db). Sem ele, o endpoint responde 401.
ADMIN_TOKEN=
